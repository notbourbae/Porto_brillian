rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check valid document IDs to prevent ID poisoning
    function isValidId(id) {
      return id is string && id.size() >= 1 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to validate Message structure
    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'message', 'timestamp'])
        && data.keys().size() == 5
        && data.id is string && data.id.size() >= 1 && data.id.size() <= 128
        && data.name is string && data.name.size() >= 1 && data.name.size() <= 200
        && data.email is string && data.email.size() >= 3 && data.email.size() <= 200
        && data.message is string && data.message.size() >= 1 && data.message.size() <= 5000
        && data.timestamp is string && data.timestamp.size() >= 10 && data.timestamp.size() <= 50;
    }

    // Messages collection rules
    match /messages/{messageId} {
      allow create: if isValidId(messageId) && isValidMessage(request.resource.data);
      allow read, delete: if true;
    }
  }
}
