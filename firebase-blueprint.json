{
  "entities": {
    "message": {
      "title": "Message",
      "description": "Reviews or messages sent from the portfolio contact form",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique ID of the message"
        },
        "name": {
          "type": "string",
          "description": "Name of the sender"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email of the sender"
        },
        "message": {
          "type": "string",
          "description": "The body of the message/review"
        },
        "timestamp": {
          "type": "string",
          "description": "ISO 8601 string representation of the submission time"
        }
      },
      "required": ["id", "name", "email", "message", "timestamp"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "message",
      "description": "Collection of visitor reviews/messages"
    }
  }
}
